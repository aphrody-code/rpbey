{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2023", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "resolveJsonModule": true,
    "allowJs": false,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "isolatedModules": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true,
    "noFallthroughCasesInSwitch": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "skipLibCheck": true,
    "declaration": false,
    "sourceMap": false,
    "incremental": true,
    "paths": {
      "@rpb/dashboard/*": ["./apps/rpbey/src/*"],
      "@rpb/bot/*": ["./apps/rpb-bot/src/*"],
      "discordx": ["./packages/discordx/packages/discordx/src/index.ts"],
      "discordx/*": ["./packages/discordx/packages/discordx/src/*"]
    }
  },
  "exclude": [
    "node_modules",
    "**/node_modules",
    "**/dist",
    "**/.next",
    "**/build",
    "**/coverage",
    ".migration-ready",
    "infra/rust/target"
  ]
}
