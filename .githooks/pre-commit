#!/usr/bin/env bash
# Hook pré-commit natif (zéro dépendance) — garde la doc structurée + synchronisée.
# Installé via `core.hooksPath=.githooks` (script `prepare` du package.json racine).
#
# Ne se déclenche que si le commit touche un .md, un package.json ou docs.ts :
#   1. régénère docs/REPO_MAP.md + docs/README.md (source de vérité = package.json + frontmatter)
#   2. normalise le format de tous les .md
#   3. re-stage les fichiers générés + les .md déjà stagés
#   4. lance `docs check` (frontmatter Zod, liens, scope, drift) — bloque le commit si erreur dure
set -euo pipefail

root="$(git rev-parse --show-toplevel)"
cd "$root"

staged="$(git diff --cached --name-only --diff-filter=ACMR)"
if ! printf '%s\n' "$staged" | grep -qE '(\.md$|/package\.json$|^scripts/docs\.ts$)'; then
  exit 0
fi

if ! command -v bun >/dev/null 2>&1; then
  echo "[docs] bun introuvable — vérification doc sautée." >&2
  exit 0
fi

echo "[docs] régénération map+index, normalisation, vérification…"
bun scripts/docs.ts map --write   >/dev/null
bun scripts/docs.ts index --write >/dev/null
bun scripts/docs.ts fmt --write   >/dev/null

# Re-stage les fichiers générés (déterministes) + les .md qui étaient déjà stagés.
git add docs/README.md docs/REPO_MAP.md
while IFS= read -r f; do
  [ -n "$f" ] || continue
  case "$f" in
    *.md) git add "$f" ;;
  esac
done <<< "$staged"

bun scripts/docs.ts check
