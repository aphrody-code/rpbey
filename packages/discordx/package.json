{
  "name": "discordy",
  "version": "0.1.0",
  "private": true,
  "description": "Bun-first fork of discordx — decorator-based Discord.js framework, consolidated as an @rpbey/* scoped workspace.",
  "keywords": [
    "api",
    "bot",
    "client",
    "decorators",
    "discord",
    "discordy",
    "framework",
    "library",
    "rpbey",
    "tool",
    "typescript"
  ],
  "homepage": "https://github.com/rpbey/discordy",
  "bugs": {
    "url": "https://github.com/rpbey/discordy/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/rpbey/discordy"
  },
  "license": "Apache-2.0",
  "contributors": [
    "Vijay Meena <vijayymmeena@gmail.com> (https://github.com/vijayymmeena)",
    "rpbey (https://github.com/rpbey)"
  ],
  "scripts": {
    "preinstall": "bun scripts/preinstall-guard.ts",
    "build:typedoc": "turbo run build:typedoc",
    "format": "biome format --write",
    "lint": "biome lint",
    "prepare": "husky",
    "prettier": "prettier --check .",
    "test": "echo 'Subpackages tested by root'"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.16",
    "@changesets/changelog-github": "^0.7.0",
    "@changesets/cli": "^2.31.0",
    "@commitlint/cli": "^21.0.2",
    "@commitlint/config-angular": "^21.0.2",
    "@types/bun": "^1.3.14",
    "husky": "^9.1.7",
    "tsup": "^8.5.1",
    "turbo": "^2.9.16",
    "typedoc": "^0.28.19",
    "typescript": "catalog:"
  },
  "publishConfig": {
    "access": "restricted"
  },
  "workspaces": [
    "packages/*",
    "packages/*/examples/**",
    "docs"
  ],
  "packageManager": "bun@1.3.14",
  "trustedDependencies": [
    "core-js",
    "core-js-pure",
    "esbuild",
    "ffmpeg-static",
    "unrs-resolver"
  ],
  "engines": {
    "bun": ">=1.2.0"
  }
}
