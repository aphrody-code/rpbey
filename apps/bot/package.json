{
	"name": "@rose-griffon/bot",
	"version": "1.0.0",
	"type": "module",
	"description": "Discord bot for RPB community",
	"main": "src/index.ts",
	"scripts": {
		"dev": "bun --watch src/index.ts",
		"patch:dht": "bash scripts/patch-dht-debug.sh",
		"prebuild": "bun run gen:entries && bun run patch:dht",
		"gen:entries": "bun scripts/gen-entry-imports.ts",
		"build": "swc -d dist src --config-file .swcrc --strip-leading-paths",
		"build:oxc": "bun scripts/build-oxc.ts",
		"build:bin": "bun scripts/build-bin.ts",
		"test:bin": "bun scripts/test-bin.ts",
		"lint": "oxlint --config .oxlintrc.json src",
		"lint:eslint": "eslint src",
		"lint:fix": "oxlint --config .oxlintrc.json --fix src",
		"start": "bun src/index.ts",
		"type-check": "bunx tsc --noEmit",
		"test": "bun test",
		"test:bridge": "bun test test/discord-activity.test.ts && bun test test/gacha-api.test.ts && bun test test/api-server.test.ts && bun test test/play-command.test.ts"
	},
	"dependencies": {
		"@paralleldrive/cuid2": "^3.3.0",
		"@rpbey/db": "workspace:*",
		"@rpbey/types": "workspace:*",
		"@rpbey/di": "workspace:*",
		"@rpbey/discordx": "workspace:*",
		"@rpbey/pagination": "workspace:*",
		"@aphrody-code/canvas": "0.1.99-fork.4",
		"drizzle-orm": "^0.45.2",
		"@twurple/api": "^8.1.3",
		"@twurple/auth": "^8.1.3",
		"@twurple/chat": "^8.1.3",
		"canvacord": "^6.0.4",
		"debug": "^4.4.0",
		"discord-html-transcripts": "3.3.0",
		"discord.js": "catalog:",
		"pg": "^8.20.0",
		"@rose-griffon/challonge": "workspace:*",
		"reflect-metadata": "^0.2.2",
		"sharp": "^0.34.5",
		"tsyringe": "^4.10.0",
		"@tobyg74/tiktok-api-dl": "^1.3.7",
		"lru-cache": "^11.3.5"
	},
	"devDependencies": {
		"@types/node": "catalog:",
		"@types/pg": "^8.20.0",
		"bun-types": "^1.3.12",
		"eslint": "catalog:",
		"eslint-plugin-import": "^2.32.0",
		"oxlint": "catalog:",
		"typescript": "catalog:"
	}
}
