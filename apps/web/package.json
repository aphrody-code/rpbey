  "scripts": {
    "dev": "bun --bun next dev",
    "dev:all": "bun run bot:dev & bun --bun next dev",
    "build": "bun --env-file=../../.env next build --turbopack",
    "start": "bun --bun next start",
    "lint": "oxlint . && bun scripts/check-dal-boundary.ts",
    "lint:fix": "oxlint --fix .",
    "lint:ox": "oxlint .",
    "dal-check": "bun scripts/check-dal-boundary.ts",
    "type-check": "bunx tsc --noEmit",
    "emit-openapi": "bun scripts/emit-openapi.ts",
    "gen:api": "bun scripts/emit-openapi.ts && bunx @hey-api/openapi-ts",
    "gen:api:check": "bun scripts/check-sdk-drift.ts",
    "bot:dev": "turbo run dev --filter rpb-bot",
    "bot:build": "turbo run build --filter rpb-bot",
    "bot:start": "turbo run start --filter rpb-bot",
    "scrape:products": "bun scripts/sync-products.ts",
    "youtube:subscribe": "bun scripts/subscribe-youtube.ts",
    "scrape:anime": "bun scripts/scrape-anime.ts",
    "clean": "rm -rf .next dist node_modules/.cache .turbo tsconfig.tsbuildinfo"
  },
