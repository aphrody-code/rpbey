[Unit]
Description=rpbey cdn — Bun-based minimal image server
After=network.target

[Service]
Type=simple
User=ubuntu
Group=ubuntu
WorkingDirectory=/home/ubuntu/rpbey/apps/cdn
EnvironmentFile=/home/ubuntu/rpbey/apps/cdn/.env
ExecStart=/home/ubuntu/.bun/bin/bun server.ts
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
