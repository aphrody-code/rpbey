# apps/cdn — variables d'environnement
# Référence : CLAUDE.md (section "CDN assets pipeline (cdn.rpbey.fr)")

# Listen
CDN_PORT=8804
CDN_HOST=127.0.0.1

# Stockage local des images live (legacy cdn.rosegriffon.fr/static/...)
CDN_STORAGE=/var/www/cdn/images

# Base publique injectée dans les URL retournées par l'API
CDN_PUBLIC_BASE=https://cdn.rosegriffon.fr

# Pipeline assets (Phase 1+2)
# CDN_REPO_ROOT=../../
# (Optional: defaults to monorepo root dynamically if left empty)
CDN_ASSETS_MANIFEST=/var/www/cdn/assets-manifest.json
CDN_VARIANTS_ROOT=/var/www/cdn/variants

# Auth pour POST /api/assets/manifest/refresh
CDN_API_KEY=
