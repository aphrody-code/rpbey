# apps/cdn — variables d'environnement
# Serverless (Cloud Run europe-west3) : binder 0.0.0.0 + lire $PORT.
# NOTE: ce service est ORPHELIN au runtime (assets servis par Vercel CDN +
# apps/web/public). Le dossier assets/ reste la SOURCE de apps/web/public
# (cf. scripts/deploy-web.sh), mais le serveur HTTP lui-même n'est plus appelé.

# Listen — la plateforme injecte $PORT ; 0.0.0.0 obligatoire en conteneur.
# PORT=8080            # (Cloud Run le fournit automatiquement)
CDN_PORT=8804          # fallback legacy/tests si $PORT absent
CDN_HOST=0.0.0.0

# Stockage éphémère uniquement (FS read-only sauf /tmp en serverless).
# Défaut = $TMPDIR/rpbey-cdn/images. Best-effort, jamais source de vérité.
# CDN_STORAGE=/tmp/rpbey-cdn/images

# Base publique injectée dans les URL retournées par l'API
CDN_PUBLIC_BASE=https://cdn.rosegriffon.fr

# Pipeline assets (Phase 1+2)
# CDN_REPO_ROOT=../../
# (Optional: defaults to monorepo root dynamically if left empty)
# CDN_ASSETS_MANIFEST=/tmp/rpbey-cdn/assets-manifest.json
# CDN_VARIANTS_ROOT=/tmp/rpbey-cdn/variants

# Auth pour POST /api/assets/manifest/refresh + /upload + DELETE
CDN_API_KEY=
