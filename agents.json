  "version": "1.0.0",
  "project": "rpbey",
  "updated": "2026-05-29",
  "mission": "Exécuter la migration API-first de apps/web (dette DAL transitive 157 -> 0) en parallèle, plusieurs sub-agents sur la MÊME branche, ZÉRO collision de fichier. Chaque lane possède un ensemble de chemins DISJOINT (garantie dure). Les fichiers d'agrégation partagés sont mono-propriété de la lane `integration` ; les autres lanes demandent le câblage via la mailbox.",
  "branch": "main",
  "plan": "~/.claude/plans/tingly-wondering-river.md",
  "board": "task.md",
  "verifier": "bun .agents/verify-ownership.ts",

  "status_values": ["todo", "active", "blocked", "review", "done"],

  "coordination": {
    "protocol": "file-mailbox (JSONL append-only) + messages[] de ce JSON pour les annonces durables",
    "mailbox_dir": ".agents/mailbox",
    "inbox_pattern": ".agents/mailbox/<lane>.inbox.jsonl",
    "outbox_pattern": ".agents/mailbox/<lane>.outbox.jsonl",
    "broadcast": ".agents/mailbox/_broadcast.jsonl",
    "envelope": {
      "id": "string — <lane>-<seq4> (ex: gacha-0007)",
      "ts": "string ISO-8601",
      "from": "lane id",
      "to": "lane id | '*' (broadcast)",
      "type": "claim | release | request-wire | wired | blocked | unblocked | review-request | review-done | done | note",
      "subject": "string court",
      "refs": ["globs de fichiers / ids de message / shas de commit"],
      "body": "markdown"
    },
    "how_to_send": "Appondre UNE ligne JSON (JSONL) au .inbox.jsonl du destinataire ET la mirroriter dans son propre .outbox.jsonl. L'orchestrateur peut aussi appondre à messages[] de ce fichier (annonces durables, lues par toutes les lanes au démarrage).",
    "read_on_start": "Chaque lane lit son .inbox.jsonl + _broadcast.jsonl + messages[] de agents.json AVANT d'agir.",
    "request_wire_flow": "Lane crée son contrat <domaine>.ts -> envoie 'request-wire' à integration (refs = export à ajouter dans index.ts, entrée ROUTES[] de openapi.ts, préfixe ENFORCED) -> integration câble en lot -> répond 'wired' -> lane continue."
  },

  "collision_policy": {
    "rule_1_disjoint_ownership": "Une lane n'édite QUE les fichiers matchant ses owns[] moins excludes[]. JAMAIS `git add -A` ; stage uniquement les chemins possédés.",
    "rule_2_shared_via_integration": "Les fichiers de shared_resources sont édités UNIQUEMENT par la lane `integration`. Les autres envoient 'request-wire' et attendent 'wired'.",
    "rule_3_claim_before_write": "Appondre un 'claim' à son outbox avant la 1re édition d'un fichier neuf (advisory ; la disjonction des globs est la garantie dure).",
    "rule_4_worktree_optional": "Pour une exécution 100% parallèle, spawn chaque lane avec isolation:'worktree' ; chemins disjoints => zéro conflit de merge au rebase sur la branche.",
    "rule_5_gate_before_commit": "Lancer gates.scoped_before_commit sur sa zone ; committer seulement au vert.",
    "rule_6_commit_scope": "Message conventionnel FR scopé domaine, ex: `feat(gacha): DAL + routes /api/v1/gacha`. Pas d'emoji, pas de Co-Authored-By."
  },

  "gates": {
    "type_check": "cd apps/web && bunx tsc --noEmit",
    "lint": "cd apps/web && oxlint .",
    "format_check": "bunx oxfmt --check <fichiers possédés>",
    "format_fix": "bunx oxfmt <fichiers possédés>",
    "dal_boundary": "cd apps/web && bun scripts/check-dal-boundary.ts",
    "build": "bun run build:web",
    "bot_test": "cd apps/bot && bun test",
    "scoped_before_commit": ["type_check", "lint", "dal_boundary"],
    "full_before_deploy": ["type_check", "lint", "format_check", "dal_boundary", "build"],
    "deploy": "bash apps/web/scripts/deploy-web.sh && sudo systemctl restart rpbey-web.service"
  },

