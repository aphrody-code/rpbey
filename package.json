{
  "name": "rpbey",
  "version": "1.0.0",
  "private": true,
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*",
      "packages/discordx/packages/*"
    ],
    "catalog": {
      "react": "^19.2.5",
      "react-dom": "^19.2.5",
      "next": "16.3.0-canary.32",
      "@next/bundle-analyzer": "16.3.0-canary.32",
      "@next/eslint-plugin-next": "16.3.0-canary.32",
      "eslint-config-next": "16.3.0-canary.32",
      "typescript": "^6.0.3",
      "tailwindcss": "^4.2.2",
      "@supabase/supabase-js": "^2.89.0",
      "@supabase/ssr": "^0.6.1",
      "better-auth": "^1.4.10",
      "prisma": "7.7.0",
      "@prisma/client": "7.7.0",
      "@rpbey/discordx": "^0.1.1",
      "discord.js": "^14.26.3",
      "vitest": "^4.0.18",
      "zod": "^4.4.3",
      "oxlint": "^1.64.0",
      "eslint-plugin-oxlint": "^1.64.0",
      "@types/bun": "^1.3.14",
      "@types/node": "^25.7.0",
      "@types/react": "19.2.14",
      "@types/react-dom": "19.2.3",
      "eslint": "^9.39.4"
    },
    "catalogs": {
      "testing": {
        "vitest": "^4.0.18"
      }
    }
  },
  "type": "module",
  "scripts": {
    "dev": "turbo run dev",
    "dev:web": "turbo run dev --filter=@rose-griffon/dashboard",
    "dev:bot": "turbo run dev --filter=@rose-griffon/bot",
    "build": "turbo run build",
    "build:web": "turbo run build --filter=@rose-griffon/dashboard",
    "lint": "oxlint apps packages",
    "lint:fix": "oxlint apps packages --fix",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "e2e": "CHROME=/usr/local/bin/chromium bun scripts/e2e.ts",
    "type-check": "turbo run type-check",
    "test": "turbo run test",
    "clean": "rm -rf node_modules apps/*/node_modules packages/*/node_modules .turbo apps/*/.turbo packages/*/.turbo"
  },
  "devDependencies": {
    "@happy-dom/global-registrator": "^20.9.0",
    "@types/bun": "catalog:",
    "@types/node": "catalog:",
    "oxfmt": "^0.52.0",
    "oxlint": "catalog:",
    "turbo": "^2.9.16",
    "typescript": "catalog:"
  },
  "overrides": {
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "drizzle-orm": "0.45.2",
    "zod-validation-error": "^4.0.0"
  },
  "packageManager": "bun@1.3.14",
  "trustedDependencies": [
    "bun",
    "esbuild",
    "sharp",
    "@discordjs/opus",
    "@aphrody-code/canvas",
    "canvas",
    "canvacord",
    "puppeteer",
    "prisma",
    "@prisma/engines",
    "@tsparticles/engine"
  ]
}
