{
  "name": "rpbey",
  "version": "1.0.0",
  "private": true,
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*",
      "packages/discordx/packages/*"
    ],
    "catalog": {
      "react": "^19.2.7",
      "react-dom": "^19.2.7",
      "next": "16.3.0-canary.39",
      "@next/bundle-analyzer": "16.3.0-canary.39",
      "@next/eslint-plugin-next": "16.3.0-canary.39",
      "eslint-config-next": "16.3.0-canary.39",
      "typescript": "^6.0.3",
      "tailwindcss": "^4.3.0",
      "@supabase/supabase-js": "^2.107.0",
      "@supabase/ssr": "^0.10.3",
      "better-auth": "^1.6.14",
      "prisma": "7.8.0",
      "@prisma/client": "7.8.0",
      "@rpbey/discordx": "^0.1.1",
      "discord.js": "^14.26.4",
      "vitest": "^4.1.8",
      "zod": "^4.4.3",
      "oxlint": "^1.68.0",
      "eslint-plugin-oxlint": "^1.68.0",
      "@types/bun": "^1.3.14",
      "@types/node": "^25.9.1",
      "@types/react": "19.2.16",
      "@types/react-dom": "19.2.3",
      "eslint": "^10.4.1",
      "drizzle-orm": "^0.45.2",
      "express": "^5.2.1",
      "@discord/embedded-app-sdk": "^2.5.0",
      "pixi.js": "^8.18.1",
      "@aphrody/bxc": "^0.6.0",
      "@aphrody/x": "^1.0.6",
      "@tobyg74/tiktok-api-dl": "^1.3.7",
      "@twurple/api": "^8.1.4",
      "@twurple/auth": "^8.1.4",
      "lru-cache": "^11.5.1",
      "postgres": "^3.4.9",
      "sharp": "^0.34.5",
      "@paralleldrive/cuid2": "^3.3.0"
    },
    "catalogs": {
      "testing": {
        "vitest": "^4.1.8"
      }
    }
  },
  "type": "module",
  "scripts": {
    "dev": "turbo run dev",
    "dev:web": "turbo run dev --filter=@rose-griffon/dashboard",
    "dev:bot": "turbo run dev --filter=@rose-griffon/bot",
    "build": "turbo run build",
    "build:web": "turbo run build --filter=@rose-griffon/dashboard",
    "lint": "oxlint apps packages",
    "lint:fix": "oxlint apps packages --fix",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "e2e": "CHROME=/usr/local/bin/chromium bun scripts/e2e.ts",
    "type-check": "turbo run type-check",
    "test": "turbo run test",
    "test:all": "bun scripts/test-all.ts",
    "test:ci": "bun scripts/test-all.ts --strict",
    "test:cov": "bun scripts/test-all.ts --coverage --junit",
    "test:vendored": "bun scripts/test-all.ts --vendored",
    "test:flake": "bun scripts/test-all.ts --randomize --rerun-each=3",
    "docs": "bun scripts/docs.ts map --write && bun scripts/docs.ts index --write && bun scripts/docs.ts fmt --write && bun scripts/docs.ts check",
    "docs:check": "bun scripts/docs.ts check",
    "docs:fmt": "bun scripts/docs.ts fmt --write",
    "docs:index": "bun scripts/docs.ts index --write",
    "docs:map": "bun scripts/docs.ts map --write",
    "docs:list": "bun scripts/docs.ts list",
    "prepare": "git config core.hooksPath .githooks 2>/dev/null || true",
    "clean": "rm -rf node_modules apps/*/node_modules packages/*/node_modules .turbo apps/*/.turbo packages/*/.turbo"
  },
  "devDependencies": {
    "@happy-dom/global-registrator": "^20.9.0",
    "@hey-api/openapi-ts": "^0.98.1",
    "@types/bun": "^1.3.14",
    "@types/node": "^25.9.1",
    "oxfmt": "^0.53.0",
    "oxlint": "^1.68.0",
    "turbo": "^2.9.16",
    "typescript": "^6.0.3"
  },
  "overrides": {
    "@types/react": "19.2.16",
    "@types/react-dom": "19.2.3",
    "drizzle-orm": "0.45.2",
    "next": "16.3.0-canary.39",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "zod-validation-error": "^4.0.0"
  },
  "packageManager": "bun@1.3.14",
  "trustedDependencies": [
    "bun",
    "esbuild",
    "sharp",
    "@discordjs/opus",
    "@aphrody/canvas",
    "canvas",
    "canvacord",
    "puppeteer",
    "prisma",
    "@prisma/engines",
    "@tsparticles/engine"
  ],
  "patchedDependencies": {
    "kysely@0.29.2": "patches/kysely@0.29.2.patch",
    "@aphrody/bxc-test@0.1.1": "patches/@aphrody%2Fbxc-test@0.1.1.patch"
  }
}
