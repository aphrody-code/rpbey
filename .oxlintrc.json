{
	"$schema": "./node_modules/oxlint/configuration_schema.json",
	"plugins": ["import", "typescript", "unicorn"],
	"env": {
		"node": true,
		"es2024": true
	},
	"rules": {
		"eqeqeq": "warn",
		"no-console": ["warn", { "allow": ["warn", "error"] }],
		"no-debugger": "error",
		"no-eval": "error",
		"no-unused-vars": "warn",
		"no-var": "error",
		"prefer-const": "warn",

		"typescript/no-explicit-any": "warn",
		"typescript/no-non-null-assertion": "warn",
		"typescript/consistent-type-imports": "warn",

		"import/no-cycle": "error",
		"import/no-self-import": "error",
		"import/no-duplicates": "error",
		"import/no-mutable-exports": "error",

		"unicorn/no-null": "off",
		"unicorn/prefer-node-protocol": "warn",
		"unicorn/no-array-for-each": "off"
	},
	"ignorePatterns": [
		"**/node_modules/**",
		"**/.next/**",
		"**/.turbo/**",
		"**/dist/**",
		"**/build/**",
		"**/out/**",
		"**/coverage/**",
		"**/target/**",
		"**/.bun/**",
		"**/*.min.js",
		"**/*.map",
		"**/generated/**",
		"**/prisma/migrations/**",
		"**/supabase-docker/**",
		"infra/rust/**",
		"packages/canvas/**",
		"packages/inagle/data/**",
		"apps/rpb-bot/dist/**",
		"apps/shenron/**",
		"apps/cdn/uploads/**",
		"apps/azalee/.next/**",
		"apps/rosegriffon/.next/**",
		"apps/rpbey/.next/**",
		"**/*.test.ts",
		"**/*.spec.ts",
		"**/*.test.tsx",
		"**/*.spec.tsx",
		"scripts/**",
		"**/scripts/**",
		"data/**",
		"storage/**",
		"backups/**",
		".backups/**"
	],
	"overrides": [
		{
			"files": [
				"**/*.test.ts",
				"**/*.spec.ts",
				"**/*.test.tsx",
				"**/*.spec.tsx"
			],
			"rules": {
				"typescript/no-explicit-any": "off",
				"no-console": "off"
			}
		},
		{
			"files": ["packages/**/*.ts", "packages/**/*.tsx"],
			"rules": {
				"no-console": ["warn", { "allow": ["warn", "error", "info"] }]
			}
		}
	]
}
